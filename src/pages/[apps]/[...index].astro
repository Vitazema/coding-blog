---
//Imports
import Base from "@layouts/Base.astro";
import { buildLocalizedStaticPaths } from "@i18n/utils";
import "@styles/markdown.css";

// Get current language from URL
// Localize the Apps page folder route.
// Pattern: ["apps", "...index"] → first segment fills [apps], remaining (if any) fills [...index].
export function getStaticPaths() {
    return buildLocalizedStaticPaths("/apps", ["apps", "...index"]);
}

// Props
const { lang } = Astro.props;

// Dynamically import the correct MDX file based on the language
const { Content, frontmatter } = await import(`./_apps-${lang}.mdx`);
---

<Base
    title={frontmatter?.title}
    meta={{
        description: frontmatter?.description,
        keywords: frontmatter?.keywords,
    }}
>
    <section id="md-content" aria-label="Page content">
        <Content />
    </section>
</Base>
